#!/usr/bin/env bash
set -euo pipefail

DEBUG_MODE=0
if [ "${1:-}" = "--debug" ]; then
  DEBUG_MODE=1
  shift
fi

if [ "$#" -gt 0 ]; then
  echo "Usage: $0 [--debug]" >&2
  exit 2
fi

if [ "${HTTP_PORT:-}" = "" ]; then
  HTTP_PORT=8000
  if [ "$(id -u)" = "0" ]; then
    HTTP_PORT=80
  fi
fi

if [ "${WS_PORT:-}" = "" ]; then
  WS_PORT=8080
fi

pick_free_port() {
  local port="$1"
  local tries="${2:-25}"
  local candidate="$port"
  local i=0

  while [ "$i" -lt "$tries" ]; do
    if python3 -c "import socket,sys
port = int(sys.argv[1])
for family, addr in ((socket.AF_INET, '0.0.0.0'), (socket.AF_INET6, '::')):
    s = None
    try:
        s = socket.socket(family, socket.SOCK_STREAM)
        s.bind((addr, port))
    except OSError as e:
        if family == socket.AF_INET6 and e.errno in (97, 99):
            continue
        raise
    finally:
        if s is not None:
            s.close()
" "$candidate" >/dev/null 2>&1; then
      echo "$candidate"
      return 0
    fi
    candidate=$((candidate + 1))
    i=$((i + 1))
  done
  return 1
}

if ! FREE_HTTP_PORT="$(pick_free_port "$HTTP_PORT")"; then
  echo "Failed to find a free HTTP port starting from $HTTP_PORT" >&2
  exit 1
fi

if [ "$FREE_HTTP_PORT" != "$HTTP_PORT" ]; then
  echo "HTTP port $HTTP_PORT is busy; using $FREE_HTTP_PORT instead." >&2
  HTTP_PORT="$FREE_HTTP_PORT"
fi

echo "Starting static server on port $HTTP_PORT and websocket server on port $WS_PORT"

if ! python3 -c "from PIL import Image" >/dev/null 2>&1; then
  echo "Warning: Pillow is not installed, so image resizing is disabled." >&2
  echo "Install it with: python3 -m pip install pillow" >&2
fi

if [ "$DEBUG_MODE" -eq 1 ]; then
  export KANSAS_DEBUG=1
  echo "Debug mode enabled: server logs are verbose and client debug can be enabled via ?debug=1" >&2
fi

python3 -m server.static_server "$HTTP_PORT" &
if [ "$DEBUG_MODE" -eq 1 ]; then
  ./test_server.py --debug "$WS_PORT" | tee -a kansas-server.log
else
  ./test_server.py "$WS_PORT" | tee -a kansas-server.log
fi
